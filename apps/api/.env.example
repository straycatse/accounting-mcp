# Server
NODE_ENV=development
PORT=3000
# Public https URL in production (OAuth issuer + redirect URIs)
BASE_URL=http://localhost:3000
# Public origin of the Next.js web app (apps/web). Browser-facing redirects
# (sign-in, consent, dashboard, the Bokio OAuth callback) target this origin,
# which proxies /api/*, /connect/* and /trpc/* back here. Defaults to BASE_URL
# for single-server dev/tests; set it when the web app runs separately:
# WEB_URL=http://localhost:3001

# Database (docker-compose default)
DATABASE_URL=postgres://accounting:accounting@localhost:5433/accounting_mcp

# Auth secrets — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
TOKEN_ENCRYPTION_KEY=

# Bokio integration (from https://docs.bokio.se developer portal; leave empty while BOKIO_MOCK=true)
BOKIO_CLIENT_ID=
BOKIO_CLIENT_SECRET=
BOKIO_AUTH_BASE_URL=https://api.bokio.se/v1
BOKIO_API_BASE_URL=https://api.bokio.se/v1
# Space-separated Bokio scopes; defaults to every scope documented in specs/company-api.yaml.
# Override to narrow, e.g. "company-information:read invoices:read"
# BOKIO_SCOPES=

# Fortnox integration (from https://apps.fortnox.se developer portal; leave empty while FORTNOX_MOCK=true)
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
FORTNOX_AUTH_BASE_URL=https://apps.fortnox.se/oauth-v1
FORTNOX_API_BASE_URL=https://api.fortnox.se
# Space-separated Fortnox scopes. Also selects which tools are registered —
# ops outside these scopes would only 403. Must match the permissions ticked
# for the integration at apps.fortnox.se.
# FORTNOX_SCOPES=

# Feature toggles
BOKIO_ALLOW_WRITES=false
BOKIO_MOCK=true
FORTNOX_ALLOW_WRITES=false
FORTNOX_MOCK=true

# Billing (Stripe via @better-auth/stripe). Free-for-all while false.
# When true: checkout is required before connecting a company. Checkout starts a
# Stripe-run TRIAL_DAYS trial with no card required; it cancels at trial end if
# no payment method was added. Seats = number of connected companies. Set
# billing_account.complimentary=true to exempt an account entirely (staff).
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
TRIAL_DAYS=14

# Limits
BINARY_MAX_BYTES=4194304
AUDIT_LOG_PARAMS=false
