# Both are read at BUILD time (Next inlines/bakes them — rebuild to change).

# Public origin of the API service — shown in the dashboard's MCP connector
# cards (the /mcp URL MCP clients connect to directly).
NEXT_PUBLIC_API_URL=http://localhost:3000

# Server-side rewrite target for /api/*, /connect/* and /trpc/*. On Railway,
# use the api service's private-network URL; falls back to NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=http://localhost:3000
